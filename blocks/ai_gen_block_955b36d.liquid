{% doc %}
  @prompt
    I would like a text focused metrics box style section that allows me to change all of the colors of everything. It should have a sub header and a header both of which I am able to change the font sizes of. I should be able to add up to 6 boxes that make up 3 columns of 2. Each box should allow for a header, a highlight icon like a dollar sign, percentage, asterisk or whatever, a paragraph and a tiny note at the bottom, I should be able to change the colors of each element in the box. There should be an aesthetically pleasing border around each box. I should also be able to add another small text line to the bottom of the section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-metrics-box-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px;
    background-color: {{ block.settings.section_background_color }};
  }

  .ai-metrics-box__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-metrics-box__subheader-{{ ai_gen_id }} {
    color: {{ block.settings.subheader_color }};
    font-size: {{ block.settings.subheader_font_size }}px;
    margin: 0 0 8px 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-metrics-box__heading-{{ ai_gen_id }} {
    color: {{ block.settings.header_color }};
    font-size: {{ block.settings.header_font_size }}px;
    margin: 0;
  }

  .ai-metrics-box__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 32px;
  }

  .ai-metrics-box__item-{{ ai_gen_id }} {
    background-color: {{ block.settings.box_background_color }};
    border: {{ block.settings.box_border_width }}px solid {{ block.settings.box_border_color }};
    border-radius: {{ block.settings.box_border_radius }}px;
    padding: 32px 24px;
    text-align: center;
  }

  .ai-metrics-box__item-header-{{ ai_gen_id }} {
    color: {{ block.settings.box_header_color }};
    font-size: {{ block.settings.box_header_font_size }}px;
    margin: 0 0 16px 0;
    font-weight: 600;
  }

  .ai-metrics-box__item-icon-{{ ai_gen_id }} {
    color: {{ block.settings.box_icon_color }};
    font-size: {{ block.settings.box_icon_font_size }}px;
    margin: 0 0 16px 0;
    font-weight: 700;
    line-height: 1;
  }

  .ai-metrics-box__item-paragraph-{{ ai_gen_id }} {
    color: {{ block.settings.box_paragraph_color }};
    font-size: {{ block.settings.box_paragraph_font_size }}px;
    margin: 0 0 16px 0;
    line-height: 1.6;
  }

  .ai-metrics-box__item-note-{{ ai_gen_id }} {
    color: {{ block.settings.box_note_color }};
    font-size: {{ block.settings.box_note_font_size }}px;
    margin: 0;
    font-style: italic;
  }

  .ai-metrics-box__footer-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.footer_text_color }};
    font-size: {{ block.settings.footer_text_font_size }}px;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-metrics-box__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-metrics-box-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-metrics-box__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .ai-metrics-box__header-{{ ai_gen_id }} {
      margin-bottom: 24px;
    }
  }
{% endstyle %}

<metrics-box-{{ ai_gen_id }} class="ai-metrics-box-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-metrics-box__header-{{ ai_gen_id }}">
    {% if block.settings.subheader != blank %}
      <div class="ai-metrics-box__subheader-{{ ai_gen_id }}">{{ block.settings.subheader }}</div>
    {% endif %}
    {% if block.settings.header != blank %}
      <h2 class="ai-metrics-box__heading-{{ ai_gen_id }}">{{ block.settings.header }}</h2>
    {% endif %}
  </div>

  <div class="ai-metrics-box__grid-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign box_enabled_key = 'box_' | append: i | append: '_enabled'
        assign box_header_key = 'box_' | append: i | append: '_header'
        assign box_icon_key = 'box_' | append: i | append: '_icon'
        assign box_paragraph_key = 'box_' | append: i | append: '_paragraph'
        assign box_note_key = 'box_' | append: i | append: '_note'

        assign box_enabled = block.settings[box_enabled_key]
        assign box_header = block.settings[box_header_key]
        assign box_icon = block.settings[box_icon_key]
        assign box_paragraph = block.settings[box_paragraph_key]
        assign box_note = block.settings[box_note_key]
      %}

      {% if box_enabled %}
        <div class="ai-metrics-box__item-{{ ai_gen_id }}">
          {% if box_header != blank %}
            <h3 class="ai-metrics-box__item-header-{{ ai_gen_id }}">{{ box_header }}</h3>
          {% endif %}
          {% if box_icon != blank %}
            <div class="ai-metrics-box__item-icon-{{ ai_gen_id }}">{{ box_icon }}</div>
          {% endif %}
          {% if box_paragraph != blank %}
            <div class="ai-metrics-box__item-paragraph-{{ ai_gen_id }}">{{ box_paragraph }}</div>
          {% endif %}
          {% if box_note != blank %}
            <div class="ai-metrics-box__item-note-{{ ai_gen_id }}">{{ box_note }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if block.settings.footer_text != blank %}
    <div class="ai-metrics-box__footer-{{ ai_gen_id }}">{{ block.settings.footer_text }}</div>
  {% endif %}
</metrics-box-{{ ai_gen_id }}>

<script>
  (function() {
    class MetricsBox{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('metrics-box-{{ ai_gen_id }}', MetricsBox{{ ai_gen_id }});
  })();
</script>

