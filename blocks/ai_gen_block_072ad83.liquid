{% doc %}
  @prompt
    create section that has video background that can block elements for overlay like subheading, heading, paragraph and button
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.section_height_mobile }}px;
    overflow: hidden;
    display: flex;
    align-items: {{ block.settings.content_vertical_alignment_mobile }};
    justify-content: {{ block.settings.content_horizontal_alignment_mobile }};
    background:#000;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.section_height_desktop }}px;
      align-items: {{ block.settings.content_vertical_alignment_desktop }};
      justify-content: {{ block.settings.content_horizontal_alignment_desktop }};
    }
  }

  .ai-video-hero__video-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-video-hero__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-hero__video-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-hero__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #ffffff;
    text-align: center;
    pointer-events: none;
    background-color: rgba(0, 0, 0, 0.5);
    border-radius: 4px;
  }

  .ai-video-hero__video-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
    opacity: 0.3;
  }

  .ai-video-hero__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-video-hero__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    max-width: {{ block.settings.content_max_width }}px;
    padding: 40px 20px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero__content-{{ ai_gen_id }} {
      padding: 60px 40px;
    }
  }

  .ai-video-hero__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size_mobile }}px;
    margin: 0 0 12px 0;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ai-video-hero__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_mobile }}px;
    margin: 0 0 20px 0;
    font-weight: 700;
    line-height: 1.2;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
  }
  .ai-video-hero__paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_size_mobile }}px;
    margin: 0 0 30px 0;
    line-height: 1.6;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_desktop }}px;
    }
    .ai-video-hero__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size_desktop }}px;
    }
    .ai-video-hero__paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_size_desktop }}px;
    }


  }


  .ai-video-hero__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-video-hero__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }
{% endstyle %}

<video-hero-{{ ai_gen_id }}
  class="ai-video-hero-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="flag-container">
    {% comment %} <img src="https://cdn.shopify.com/s/files/1/0397/1946/9215/files/Rescue_Graphic_GIF_American_Flag_150x150_6_sec.gif?v=1773847278" class="flag" width="200" height="200"> {% endcomment %}
    {% comment %} <img src="https://upload.wikimedia.org/wikipedia/commons/a/a4/Flag_of_the_United_States.svg" class="flag" width="200" height="200"> {% endcomment %}
    <img src="https://cdn.shopify.com/s/files/1/0397/1946/9215/files/Flag_of_the_United_States-optimized.webp?v=1773954344" class="flag" width="200" height="200" alt="US flag">
    
    
  </div>
  <div class="ai-video-hero__video-wrapper-{{ ai_gen_id }}">
    {% if block.settings.video_url != blank %}
      <video
        class="ai-video-hero__video-{{ ai_gen_id }}"
        autoplay
        muted
        loop
        playsinline
        {% if block.settings.video_poster %}
          poster="{{ block.settings.video_poster | image_url: width: 2000 }}"
        {% endif %}
      >
        <source src="{{ block.settings.video_url }}" type="video/mp4">
      </video>
    {% else %}
      <div class="ai-video-hero__video-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-video-hero__empty-state-{{ ai_gen_id }}">
          Next, add a video URL
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-video-hero__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-video-hero__content-{{ ai_gen_id }}">
    {% if block.settings.subheading != blank %}
      <div class="ai-video-hero__subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-video-hero__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.paragraph != blank %}
      <div class="ai-video-hero__paragraph-{{ ai_gen_id }}">
        {{ block.settings.paragraph }}
      </div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-video-hero__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</video-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.video = this.querySelector('.ai-video-hero__video-{{ ai_gen_id }}');
      }

      connectedCallback() {
        if (this.video) {
          this.video.play().catch(function() {});
        }
      }
    }

    customElements.define('video-hero-{{ ai_gen_id }}', VideoHero{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
