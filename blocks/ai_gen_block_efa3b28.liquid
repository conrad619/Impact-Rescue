{% doc %}
  @prompt
    I'd like  a section that shows four 16:9 videos on desktop but hides two behind a horizontal scroll on mobile, that allows for control over the corner radius and video size as well as it allows for me to select videos from our library of files and autoplays the video., sorry I meant 9:16 videos
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-gallery-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-video-gallery__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-video-gallery__item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    overflow: hidden;
    border-radius: {{ block.settings.corner_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-video-gallery__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-gallery__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    position: relative;
  }

  .ai-video-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-video-gallery__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-video-gallery__container-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: {{ block.settings.gap }}px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      flex-wrap:nowrap;
    }

    .ai-video-gallery__container-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-video-gallery__item-{{ ai_gen_id }} {
      {% comment %} flex: 0 0 calc(50% - {{ block.settings.gap | divided_by: 2 }}px); {% endcomment %}
      flex: 0 0 80%;
      scroll-snap-align: start;
    }
  }
{% endstyle %}

<video-gallery-{{ ai_gen_id }}
  class="ai-video-gallery-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-gallery__container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign video_key = 'video_' | append: i
        assign video = block.settings[video_key]
      %}
      
      <div class="ai-video-gallery__item-{{ ai_gen_id }}">
        {% if video %}
          <video
            class="ai-video-gallery__video-{{ ai_gen_id }}"
            autoplay
            muted
            loop
            playsinline
          >
            {% for source in video.sources %}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {% endfor %}
          </video>
        {% else %}
          <div class="ai-video-gallery__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-video-gallery__empty-state-{{ ai_gen_id }}">
              Add video {{ i }}
            </div>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</video-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.videos = this.querySelectorAll('.ai-video-gallery__video-{{ ai_gen_id }}');
        this.handleVideoPlayback();
      }

      handleVideoPlayback() {
        this.videos.forEach((video) => {
          video.play().catch(() => {
            video.muted = true;
            video.play();
          });
        });
      }
    }

    customElements.define('video-gallery-{{ ai_gen_id }}', VideoGallery{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Video gallery",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Videos"
    },
    {
      "type": "video",
      "id": "video_1",
      "label": "Video 1"
    },
    {
      "type": "video",
      "id": "video_2",
      "label": "Video 2"
    },
    {
      "type": "video",
      "id": "video_3",
      "label": "Video 3"
    },
    {
      "type": "video",
      "id": "video_4",
      "label": "Video 4"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between videos",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Video gallery"
    }
  ]
}
{% endschema %}
