        "full_width": true,
        "html": "<section class=\"compare-grill-rescue\">\n  <style>\n    .compare-grill-rescue {\n      padding: 30px 16px 40px;\n      font-family: Arial, Helvetica, sans-serif;\n      color: #222;\n    }\n\n    .compare-grill-rescue * {\n      box-sizing: border-box;\n    }\n\n    .compare-grill-rescue .compare-wrap {\n      max-width: 1600px;\n      margin: 0 auto;\n    }\n\n    .compare-grill-rescue .compare-title {\n      text-align: center;\n      margin: 0 0 6px;\n      font-size: 28px;\n      font-weight: 700;\n    }\n\n    .compare-grill-rescue .compare-subtitle {\n      text-align: center;\n      margin: 0 0 24px;\n      font-size: 14px;\n      letter-spacing: 0.5px;\n      color: #555;\n    }\n\n    .compare-grill-rescue .compare-table {\n      display: grid;\n      grid-template-columns: 1.1fr 1fr 1fr 1fr;\n      gap: 0;\n      align-items: stretch;\n    }\n\n    .compare-grill-rescue .cell {\n      padding: 14px 18px;\n    }\n\n    .compare-grill-rescue .header-empty {\n      background: transparent;\n    }\n\n    .compare-grill-rescue .header {\n      background: #c94536;\n      color: #fff;\n      text-align: center;\n      font-size: 24px;\n      font-weight: 500;\n      padding: 14px 10px;\n      width:100%;\n    }\n\n    .compare-grill-rescue .type-label {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      min-height: 175px;\n      font-size: 23px;\n      font-weight: 500;\n    }\n\n    .compare-grill-rescue .product-image {\n      min-height: 175px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 20px;\n      mix-blend-mode: darken;\n    }\n\n    .compare-grill-rescue .product-image img {\n      max-width: 100%;\n      max-height: 130px;\n      object-fit: contain;\n      display: block;\n    }\n\n    .compare-grill-rescue .feature {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      min-height: 52px;\n      font-size: 18px;\n      line-height: 1.3;\n      border-bottom: 1px solid #9d9d9d;\n      padding-left: 10px;\n      padding-right: 10px;\n    }\n\n    .compare-grill-rescue .value {\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      min-height: 52px;\n      font-size: 28px;\n      font-weight: 700;\n    }\n\n    .compare-grill-rescue .yes {\n      color: #3d4246;\n    }\n\n    .compare-grill-rescue .no {\n      color: #d63c30;\n    }\n\n    .compare-grill-rescue .button-row {\n      min-height: 74px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .compare-grill-rescue .shop-button {\n      display: inline-block;\n      background: #c94536;\n      color: #fff;\n      text-decoration: none;\n      padding: 12px 28px;\n      border-radius: 999px;\n      font-size: 14px;\n      font-weight: 700;\n      letter-spacing: 0.5px;\n      transition: opacity 0.2s ease;\n      text-align: center;\n      white-space: nowrap;\n    }\n\n    .compare-grill-rescue .shop-button:hover {\n      opacity: 0.9;\n    }\n\n    /* Tablet */\n    @media (max-width: 991px) {\n      .compare-grill-rescue .compare-table {\n        grid-template-columns: 1.4fr 1fr 1fr 1fr;\n      }\n\n      .compare-grill-rescue .header {\n        font-size: 20px;\n      }\n\n      .compare-grill-rescue .type-label {\n        font-size: 18px;\n        min-height: 150px;\n      }\n\n      .compare-grill-rescue .product-image {\n        min-height: 150px;\n      }\n\n      .compare-grill-rescue .feature {\n        font-size: 15px;\n      }\n\n      .compare-grill-rescue .value {\n        font-size: 24px;\n      }\n    }\n\n    /* Mobile */\n    @media (max-width: 767px) {\n      .compare-grill-rescue {\n        padding: 24px 12px 30px;\n      }\n\n      .compare-grill-rescue .compare-title {\n        font-size: 24px;\n        line-height: 1.2;\n      }\n\n      .compare-grill-rescue .compare-subtitle {\n        font-size: 13px;\n        line-height: 1.4;\n        margin-bottom: 18px;\n      }\n\n      .compare-grill-rescue .compare-table {\n        grid-template-columns: 1.5fr 1fr 1fr 1fr;\n        min-width: 760px;\n      }\n\n      .compare-grill-rescue .compare-scroll {\n        overflow-x: auto;\n        -webkit-overflow-scrolling: touch;\n      }\n\n      .compare-grill-rescue .cell {\n        padding: 10px 8px;\n      }\n\n      .compare-grill-rescue .header {\n        font-size: 16px;\n        line-height: 1.2;\n        padding: 12px 8px;\n      }\n\n      .compare-grill-rescue .type-label {\n        font-size: 16px;\n        min-height: 120px;\n        line-height: 1.3;\n      }\n\n      .compare-grill-rescue .product-image {\n        min-height: 120px;\n        padding: 12px;\n      }\n\n      .compare-grill-rescue .product-image img {\n        max-height: 85px;\n      }\n\n      .compare-grill-rescue .feature {\n        justify-content: flex-start;\n        text-align: left;\n        font-size: 14px;\n        min-height: 54px;\n        line-height: 1.35;\n      }\n\n      .compare-grill-rescue .value {\n        font-size: 22px;\n        min-height: 54px;\n      }\n\n      .compare-grill-rescue .button-row {\n        min-height: 68px;\n      }\n\n      .compare-grill-rescue .shop-button {\n        font-size: 12px;\n        padding: 10px 18px;\n      }\n    }\n\n    /* Very small phones */\n    @media (max-width: 480px) {\n      .compare-grill-rescue .compare-title {\n        font-size: 21px;\n      }\n\n      .compare-grill-rescue .compare-subtitle {\n        font-size: 12px;\n      }\n\n      .compare-grill-rescue .compare-table {\n        min-width: 700px;\n      }\n\n      .compare-grill-rescue .feature {\n        font-size: 13px;\n      }\n\n      .compare-grill-rescue .header {\n        font-size: 15px;\n      }\n    }\n  </style>\n\n  <div class=\"compare-wrap\">\n    <h2 class=\"compare-title\">Compare Grill Rescue</h2>\n    <p class=