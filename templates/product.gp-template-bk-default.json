iv>\n\n        <div class=\"cell feature\">Uses Steam To Clean</div>\n        <div class=\"cell value yes\">✓</div>\n        <div class=\"cell value no\">✕</div>\n        <div class=\"cell value no\">✕</div>\n\n        <div class=\"cell feature\">Has A Long Life Span</div>\n        <div class=\"cell value yes\">✓</div>\n        <div class=\"cell value no\">✕</div>\n        <div class=\"cell value no\">✕</div>\n\n        <div class=\"cell feature\">Dishwasher Friendly</div>\n        <div class=\"cell value yes\">✓</div>\n        <div class=\"cell value no\">✕</div>\n        <div class=\"cell value no\">✕</div>\n\n        <div class=\"cell feature\">Can Use On A Hot Surface</div>\n        <div class=\"cell value yes\">✓</div>\n        <div class=\"cell value no\">✕</div>\n        <div class=\"cell value yes\">✓</div>\n\n        <div class=\"cell feature\">Doesn’t Get Clogged With Grease And Grime</div>\n        <div class=\"cell value yes\">✓</div>\n        <div class=\"cell value no\">✕</div>\n        <div class=\"cell value yes\">✓</div>\n\n        <div class=\"cell button-row\"></div>\n        <div class=\"cell button-row\">\n          <a href=\"#main\" class=\"shop-button\">SHOP GRILL RESCUE</a>\n        </div>\n        <div class=\"cell button-row\"></div>\n        <div class=\"cell button-row\"></div>\n      </div>\n    </div>\n  </div>\n</section>",
