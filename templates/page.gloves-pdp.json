        "liquid": "<script>\ndocument.addEventListener('DOMContentLoaded', () => {\n  const discount = 'GRPDPGLOVES';\n  const buybutton = 'button_XHUNJJ';\n\n  const qtyInput = document.querySelector('.quantity-selector__input');\n  const button = document.querySelector(`[data-block-id=\"${buybutton}\"] .button`);\n  const productForm = document.querySelector('form.shopify-product-form');\n\n  if (!qtyInput || !button || !productForm) return;\n\n  const getVariantId = () => {\n    const idInput = productForm.querySelector('input[name=\"id\"]');\n    return idInput?.value;\n  };\n\n  const updatePermalink = () => {\n    const qty = parseInt(qtyInput.value, 10) || 1;\n    const variantId = getVariantId();\n\n    if (!variantId) return;\n\n    button.href = `/cart/${variantId}:${qty}?discount=${discount}&storefront=true`;\n  };\n\n  updatePermalink();\n\n  qtyInput.addEventListener('input', updatePermalink);\n  qtyInput.addEventListener('change', updatePermalink);\n\n  productForm.addEventListener('change', updatePermalink);\n\n  const observer = new MutationObserver(updatePermalink);\n\n  observer.observe(productForm, {\n    attributes: true,\n    childList: true,\n    subtree: true,\n    attributeFilter: ['value', 'disabled']\n  });\n});\n</script>",
