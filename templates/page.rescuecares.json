dding_vertical":4,"padding_sides":0,"card_padding_horizontal":14,"card_padding_vertical":7}},"payment_terms_FN4Uqj":{"type":"payment_terms","settings":{}},"pickup_availability_ybLc9D":{"type":"pickup_availability","settings":{}}},"block_order":["title_a8E6mV","badges_wtdFf4","price_MTgnEi","rating_bKjeCF","separator_DF8MCg","description_WtVVyx","variant_picker_MFG3P7","quantity_selector_mp34RW","buy_buttons_UnYzHe","button_mAexyT","section_store_block_badge_xEENKa","payment_terms_FN4Uqj","pickup_availability_ybLc9D"],"custom_css":["{padding-top: 50px; padding-bottom: 100px;}"],"name":"Featured product","settings":{"full_width":true,"product":"rescue-grilling-gloves-usa-edition","desktop_media_width":45,"desktop_media_layout":"carousel_thumbnails_left","mobile_media_size":"expanded","mobile_carousel_control":"floating_dots","flip":true,"enable_video_autoplay":true,"enable_video_looping":false,"enable_image_zoom":true,"max_image_zoom_level":3,"background":"","background_gradient":"","text_color":"","input_background":"rgba(0,0,0,0)","input_text_color":""}},"faq_LaByzJ":{"type":"faq","blocks":{"item_PMc6gw":{"type":"item","settings":{"title":"Revolutionize Your Grilling Experience with Grill Rescue","content":"<p>Grill Rescue proudly introduces its unparalleled grilling collection, anchored by the renowned <a href=\"https:\/\/grillrescue.com\/products\/grill-brush-w-scraper\"><span style=\"text-decoration:underline\">World's Best Grill Brush<\/span><\/a>. Engineered by a <a href=\"https:\/\/grillrescue.com\/pages\/heroes\"><span style=\"text-decoration:underline\">firefighter<\/span><\/a>, this collection brings innovation and safety to the forefront, ensuring your grilling endeavors are elevated to new heights. Whether you're looking for <a href=\"https:\/\/grillrescue.com\/products\/rescue-grilling-gloves-pre-sale\"><span style=\"text-decoration:underline\">premium gloves<\/span><\/a>, <a href=\"https:\/\/grillrescue.com\/products\/apron\"><span style=\"text-decoration:underline\">aprons <\/span><\/a>or the classic <a href=\"https:\/\/grillrescue.com\/products\/dunk-tank\"><span style=\"text-decoration:underline\">dunk tank<\/span><\/a>, Grill Rescue has it all.<\/p>"}},"item_XxwTrY":{"type":"item","settings":{"title":"The World's Best Grill Brush: Unleashing the Power of Steam","content":"<p>Unlike traditional brushes, Grill Rescue embraces the power of steam to clean your grill thoroughly. With a <a href=\"https:\/\/grillrescue.com\/products\/cleaning-heads-w-scraper\"><span style=\"text-decoration:underline\">cleaning head<\/span><\/a> made from super durable aramid fiber, the same material used in firefighter gear, and a robust stainless steel scraper, this brush is a game-changer. The heat-resistant cleaning head, just as revolutionary as your <a href=\"https:\/\/grillrescue.com\/products\/forever-sponge\"><span style=\"text-decoration:underline\">cleaning sponge<\/span><\/a>, detaches easily for replacement or cleaning, ensuring a consistently effective and safe grilling experience. Discover the <a href=\"https:\/\/grillrescue.com\/products\/rescue-pro\"><span style=\"text-decoration:underline\">Rescue Pro<\/span><\/a> for even more premium durability and quality.<\/p>"}},"item_EY9UrR":{"type":"item","settings":{"title":"Firefighter-Crafted Excellence: Unmatched Quality and Durability","content":"<p>Crafted by a firefighter, Grill Rescue embodies a commitment to excellence and safety. Trust that you have the best materials on Earth packed into a grill brush that addresses every concern associated with traditional wire bristle brushes. Our firefighter-inspired design prioritizes durability, with a <a href=\"https:\/\/grillrescue.com\/products\/grill-rescue-handle\"><span style=\"text-decoration:underline\">handle <\/span><\/a>so robust it can withstand being run over by a truck – a testament to its strength and reliability. Say farewell to aggressive brushing with Grill Rescue's steam-powered cleaning technology. Beyond creating superior products, Grill Rescue is committed to giving back. Founded on the principles of supporting those who serve, we donate to first responders in need through our foundation. <br\/><br\/><\/p>"}}},"block_order":["item_PMc6gw","item_XxwTrY","item_EY9UrR"],"custom_css":["summary h2 {font-size: 18px;}","@media screen and (min-width: 750px) {summary span {font-size: 24px; }}"],"name":"FAQ","settings":{"full_width":true,"subheading":"","title":"","content":"","team_avatar_width":180,"support_hours":"","answer_time":"","button_text":"","button_url":"","text_position":"center","background":"","background_gradient":"","text_color":"","heading_color":"","heading_gradient":"","button_background":"","button_text_color":"","accordion_background":"","accordion_text_color":""}}},"order":["main","blocks_tA3bTB","featured_collection_k6CPta","ss_scrolling_logo_cloud_HKCztC","featured_collection_BnEwKA","rich_text_pDnV3f","blocks_VFU8EQ","collection_list_rf3yYe","rich_text_WzjJwQ","featured_product_pBDz4E","featured_product_BX8HFR","faq_LaByzJ"]}