{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.section_height_mobile }}px;
    overflow: hidden;
    display: flex;
    align-items: {{ section.settings.content_vertical_alignment_mobile }};
    justify-content: {{ section.settings.content_horizontal_alignment_mobile }};
    background: #000;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-{{ ai_gen_id }} {
      min-height: {{ section.settings.section_height_desktop }}px;
      align-items: {{ section.settings.content_vertical_alignment_desktop }};
      justify-content: {{ section.settings.content_horizontal_alignment_desktop }};
    }
  }

  .ai-video-hero__video-wrapper-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .ai-video-hero__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-hero__video-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-hero__video-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
    opacity: 0.3;
  }

  .ai-video-hero__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #ffffff;
    text-align: center;
    pointer-events: none;
    background-color: rgba(0, 0, 0, 0.5);
    border-radius: 4px;
  }

  .ai-video-hero__overlay-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-video-hero__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
    padding: 40px 20px;
    text-align: {{ section.settings.text_alignment }};
    color: {{ section.settings.text_color }};
    margin:0 auto;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero__content-{{ ai_gen_id }} {
      padding: 60px 40px;
    }
  }

  .ai-video-hero__block-{{ ai_gen_id }} {
    margin-top: 0;
  }

  .ai-video-hero__subheading-{{ ai_gen_id }} {
    font-size: {{ section.settings.subheading_size_mobile }}px;
    margin: 0 0 12px;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .ai-video-hero__heading-{{ ai_gen_id }} {
    font-size: {{ section.settings.heading_size_mobile }}px;
    margin: 0 0 20px;
    line-height: 1.2;
    font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
    font-weight: {{ section.settings.heading_font.weight }};
  }

  .ai-video-hero__text-{{ ai_gen_id }} {
    font-size: {{ section.settings.paragraph_size_mobile }}px;
    margin: 0 0 30px;
    line-height: 1.6;
  }

  .ai-video-hero__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 32px;
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .ai-video-hero__button-{{ ai_gen_id }}:hover {
    background-color: {{ section.settings.button_hover_background }};
    color: {{ section.settings.button_hover_text_color }};
  }

  .ai-video-hero__image-{{ ai_gen_id }} {
    display: inline-block;
    max-width: 100%;
    height: auto;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero__subheading-{{ ai_gen_id }} {
      font-size: {{ section.settings.subheading_size_desktop }}px;
    }

    .ai-video-hero__heading-{{ ai_gen_id }} {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }

    .ai-video-hero__text-{{ ai_gen_id }} {
      font-size: {{ section.settings.paragraph_size_desktop }}px;
    }
  }


  .flag-container-{{ ai_gen_id }} img {
    display: block;
    max-width: {{ section.settings.flag_width }}px;
  }
{% endstyle %}

<video-hero-{{ ai_gen_id }}
  class="ai-video-hero-{{ ai_gen_id }}"
>
  {% if section.settings.show_flag %}
    <div class="flag-container flag-container-{{ ai_gen_id }}">
      <img
        src="https://cdn.shopify.com/s/files/1/0397/1946/9215/files/Flag_of_the_United_States-optimized.webp?v=1773954344"
        class="flag"
        width="{{ section.settings.flag_width }}"
        height="{{ section.settings.flag_width }}"
        alt="US flag"
        loading="lazy"
      >
    </div>
  {% endif %}

  

  <div class="ai-video-hero__video-wrapper-{{ ai_gen_id }}">
    {% if section.settings.video_url != blank %}
      <video
        class="ai-video-hero__video-{{ ai_gen_id }}"
        autoplay
        muted
        loop
        playsinline
        {% if section.settings.video_poster %}
          poster="{{ section.settings.video_poster | image_url: width: 2000 }}"
        {% endif %}
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% else %}
      <div class="ai-video-hero__video-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-video-hero__empty-state-{{ ai_gen_id }}">
          Next, add a video URL
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-video-hero__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-video-hero__content-{{ ai_gen_id }}">
    <div class="extra-image">
        <img
        src="https://cdn.shopify.com/s/files/1/0397/1946/9215/files/Rescue_Graphics_Website_Homepage_Memorial_Day_Graphic_Honoring_Our_Heroes_Circle_Banner.png?v=1779319920"
        class="flag"
        width="150"
        height="150"
        alt="Honoring Heroes"
        loading="lazy"
        >
    </div>
    <div class="ai-video-hero__wrapper-{{ ai_gen_id }}">
      {% for block in section.blocks %}
        {% case block.type %}

          {% when 'subheading' %}
            {% if block.settings.text != blank %}
              <div
                class="ai-video-hero__block-{{ ai_gen_id }} ai-video-hero__subheading-{{ ai_gen_id }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>
            {% endif %}

          {% when 'heading' %}
            {% if block.settings.text != blank %}
              <h2
                class="ai-video-hero__block-{{ ai_gen_id }} ai-video-hero__heading-{{ ai_gen_id }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </h2>
            {% endif %}

          {% when 'text' %}
            {% if block.settings.text != blank %}
              <div
                class="ai-video-hero__block-{{ ai_gen_id }} ai-video-hero__text-{{ ai_gen_id }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>
            {% endif %}

          {% when 'button' %}
            {% if block.settings.button_text != blank %}
              <div {{ block.shopify_attributes }}>
                <a
                  href="{{ block.settings.button_link | default: '#' }}"
                  class="ai-video-hero__button-{{ ai_gen_id }}"
                >
                  {{ block.settings.button_text }}
                </a>
              </div>
            {% endif %}

          {% when 'image' %}
            {% if block.settings.image != blank %}
              <div {{ block.shopify_attributes }}>
                <img
                  src="{{ block.settings.image | image_url: width: block.settings.image_width }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  width="{{ block.settings.image_width }}"
                  height="auto"
                  loading="lazy"
                  class="ai-video-hero__image-{{ ai_gen_id }}"
                >
              </div>
            {% endif %}

        {% endcase %}
      {% endfor %}
    </div>
  </div>
</video-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.video = this.querySelector('.ai-video-hero__video-{{ ai_gen_id }}');
      }

      connectedCallback() {
        if (this.video) {
          this.video.play().catch(function() {});
        }
      }
    }

    if (!customElements.get('video-hero-{{ ai_gen_id }}')) {
      customElements.define('video-hero-{{ ai_gen_id }}', VideoHero{{ ai_gen_id }});
    }
  })();
</script>

{% schema %}
{
