{% style %}
  .helping-heroes-{{ section.id }} img {
    width: 100%;
    display: block;
    border-radius: 6px;
  }

  .helping-heroes-{{ section.id }} .container {
    max-width: 1140px;
    margin: auto;
    padding: 0 20px;
  }

  .helping-heroes-{{ section.id }} section,
  .helping-heroes-{{ section.id }} .section-block {
    padding: 60px 0;
  }

  .helping-heroes-{{ section.id }} .hero {
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    color: #fff;
    overflow: hidden;
  }

  .helping-heroes-{{ section.id }} .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .helping-heroes-{{ section.id }} .hero-bg-slide {
    position: absolute;
    inset: 0;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .helping-heroes-{{ section.id }} .hero-bg-slide.is-active {
    opacity: 1;
  }

  .helping-heroes-{{ section.id }} .hero-overlay {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, {{ section.settings.hero_overlay_opacity | divided_by: 100.0 }});
    z-index: 1;
  }

  .helping-heroes-{{ section.id }} .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    padding: 20px;
  }

  .helping-heroes-{{ section.id }} .hero h1 {
    font-size: 52px;
    font-weight: 300;
    margin-bottom: 10px;
    color: inherit;
  }

  .helping-heroes-{{ section.id }} .hero p {
    font-size: 20px;
    margin-bottom: 20px;
  }

  .helping-heroes-{{ section.id }} .btn {
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
    padding: 14px 26px;
    border: none;
    border-radius: 4px;
    font-weight: bold;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }

  .helping-heroes-{{ section.id }} .two-col {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  .helping-heroes-{{ section.id }} .section-title {
    font-size: 30px;
    margin-bottom: 15px;
    text-transform: uppercase;
  }

  .helping-heroes-{{ section.id }} .card {
    background: #fff;
    border-radius: 8px;
    padding: 28px;
    border: 1px solid #ddd;
    margin-top: 20px;
    text-align: center;
  }

  .helping-heroes-{{ section.id }} .impact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 20px;
  }

  .helping-heroes-{{ section.id }} .red-card {
    background: {{ section.settings.accent_color }};
    color: #fff;
    padding: 24px;
    border-radius: 8px;
  }

  .helping-heroes-{{ section.id }} .white-card {
    background: #fff;
    border: 1px solid #ddd;
    padding: 24px;
    border-radius: 8px;
  }

  .helping-heroes-{{ section.id }} .center {
    text-align: center;
  }

  .helping-heroes-{{ section.id }} .help-card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #ddd;
    height: 100%;
  }

  .helping-heroes-{{ section.id }} .help-card-content {
    padding: 16px;
  }

  .helping-heroes-{{ section.id }} .help-card h3 {
    font-size: 14px;
    color: {{ section.settings.accent_color }};
    margin-bottom: 10px;
  }

  .helping-heroes-{{ section.id }} .amount {
    font-size: 26px;
  }

  .helping-heroes-{{ section.id }} .progress {
    height: 6px;
    background: #ddd;
    margin: 10px 0;
    border-radius: 999px;
    overflow: hidden;
  }

  .helping-heroes-{{ section.id }} .progress-bar {
    height: 100%;
    background: {{ section.settings.accent_color }};
  }

  .helping-heroes-{{ section.id }} .support-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    align-items: center;
  }

  .helping-heroes-{{ section.id }} .support-grid img {
    border-radius: 10px;
  }

  .helping-heroes-{{ section.id }} .support-grid h3 {
    font-size: 30px;
    margin-bottom: 20px;
  }

  .helping-heroes-{{ section.id }} .support-grid p {
    font-size: 20px;
  }

  .helping-heroes-{{ section.id }} .overlay-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-top: 30px;
  }

  .helping-heroes-{{ section.id }} .overlay-card {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    min-height: 420px;
  }

  .helping-heroes-{{ section.id }} .overlay-card > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }

  .helping-heroes-{{ section.id }} .overlay-card h3 {
    font-size: 20px;
    margin-bottom: 20px;
    color: inherit;
  }

  .helping-heroes-{{ section.id }} .overlay-card p {
    font-size: 14px;
    margin-bottom: 30px;
  }

  .helping-heroes-{{ section.id }} .overlay-card .details {
    max-width: 50%;
    width: 100%;
  }

  .helping-heroes-{{ section.id }} .overlay-card .btn {
    align-self: flex-start;
  }

  .helping-heroes-{{ section.id }} .overlay {
    position: relative;
    inset: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_card_opacity | divided_by: 100.0 }});
    color: #fff;
    padding: 50px 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 420px;
  }

  .helping-heroes-{{ section.id }} .payment {
    text-align: center;
    margin-top: 30px;
  }

  .helping-heroes-{{ section.id }} .payment img {
    max-width: 500px;
    margin: auto;
  }

  .helping-heroes-{{ section.id }} .gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 30px;
  }

  .helping-heroes-{{ section.id }} .responders .btn {
    padding: 16px 30px;
    margin-top: 30px;
    font-size: 24px;
    width: 70%;
    margin-left: auto;
    margin-right: auto;
  }

  .helping-heroes-{{ section.id }} .help-carousel {
    position: relative;
    margin-top: 30px;
  }

  .helping-heroes-{{ section.id }} .help-carousel__viewport {
    overflow: hidden;
  }

  .helping-heroes-{{ section.id }} .help-carousel__track {
    display: flex;
    gap: 24px;
    transition: transform 0.4s ease;
    will-change: transform;
  }

  .helping-heroes-{{ section.id }} .help-carousel__slide {
    min-width: calc((100% - 48px) / 3);
    flex: 0 0 calc((100% - 48px) / 3);
  }

  .helping-heroes-{{ section.id }} .help-carousel__arrow {
    position: absolute;
    top: 42%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 999px;
    background: #fff;
    color: #111;
    box-shadow: 0 4px 14px rgba(0,0,0,0.15);
    cursor: pointer;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    line-height: 1;
  }

  .helping-heroes-{{ section.id }} .help-carousel__arrow[disabled] {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .helping-heroes-{{ section.id }} .help-carousel__arrow--prev {
    left: -22px;
  }

  .helping-heroes-{{ section.id }} .help-carousel__arrow--next {
    right: -22px;
  }

  .helping-heroes-{{ section.id }} .help-carousel__dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 20px;
  }

  .helping-heroes-{{ section.id }} .help-carousel__dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    border: 0;
    background: #cfcfcf;
    cursor: pointer;
    padding: 0;
  }

  .helping-heroes-{{ section.id }} .help-carousel__dot.is-active {
    background: {{ section.settings.accent_color }};
  }

  @media (max-width: 900px) {
    .helping-heroes-{{ section.id }} .overlay-card .details {
      max-width: 100%;
      width: 100%;
      padding-right: 30px;
    }

    .helping-heroes-{{ section.id }} .overlay {
      padding: 50px 30px;
    }

    .helping-heroes-{{ section.id }} .responders .btn {
      width: 100%;
      font-size: 18px;
    }

    .helping-heroes-{{ section.id }} .two-col,
    .helping-heroes-{{ section.id }} .support-grid,
    .helping-heroes-{{ section.id }} .impact-grid,
    .helping-heroes-{{ section.id }} .overlay-grid,
    .helping-heroes-{{ section.id }} .gallery {
      grid-template-columns: 1fr;
    }

    .helping-heroes-{{ section.id }} .hero h1 {
      font-size: 34px;
    }

    .helping-heroes-{{ section.id }} .help-carousel__slide {
      min-width: calc((100% - 16px) / 2);
      flex: 0 0 calc((100% - 16px) / 2);
    }

    .helping-heroes-{{ section.id }} .help-carousel__track {
      gap: 16px;
    }

    .helping-heroes-{{ section.id }} .help-carousel__arrow--prev {
      left: -10px;
    }

    .helping-heroes-{{ section.id }} .help-carousel__arrow--next {
      right: -10px;
    }
  }

  @media (max-width: 640px) {
    .helping-heroes-{{ section.id }} .help-carousel__slide {
      min-width: 100%;
      flex: 0 0 100%;
    }

    .helping-heroes-{{ section.id }} .help-carousel__arrow {
      width: 38px;
      height: 38px;
      top: 38%;
    }

    .helping-heroes-{{ section.id }} .help-carousel__arrow--prev {
      left: 8px;
    }

    .helping-heroes-{{ section.id }} .help-carousel__arrow--next {
      right: 8px;
    }
  }
{% endstyle %}

<div class="helping-heroes-{{ section.id }}">
  <section
    class="hero"
    data-hero-carousel
    data-autoplay-speed="{{ section.settings.hero_autoplay_speed | times: 1000 }}"
    >
    <div class="hero-bg">
        {% assign hero_slide_count = 0 %}
        {% for block in section.blocks %}
        {% if block.type == 'hero_slide' %}
            {% assign hero_slide_count = hero_slide_count | plus: 1 %}
            <div
            class="hero-bg-slide {% if hero_slide_count == 1 %}is-active{% endif %}"
            style="background-image: url('{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 2400 }}{% endif %}');"
            {{ block.shopify_attributes }}
            ></div>
        {% endif %}
        {% endfor %}

        {% if hero_slide_count == 0 and section.settings.hero_bg != blank %}
        <div
            class="hero-bg-slide is-active"
            style="background-image: url('{{ section.settings.hero_bg | image_url: width: 2400 }}');"
        ></div>
        {% endif %}
    </div>

    <div class="hero-overlay"></div>

    <div class="hero-content">
        {% if section.settings.hero_heading != blank %}
        <h1>{{ section.settings.hero_heading }}</h1>
        {% endif %}

        {% if section.settings.hero_subheading != blank %}
        <p>{{ section.settings.hero_subheading }}</p>
        {% endif %}

        {% if section.settings.hero_button_label != blank and section.settings.hero_button_link != blank %}
        <a href="{{ section.settings.hero_button_link }}" class="btn">
            {{ section.settings.hero_button_label }}
        </a>
        {% endif %}
    </div>
    </section>

  <section class="section-block">
    <div class="container">
      <div class="two-col">
        <div>
          {% if section.settings.who_title != blank %}
            <h2 class="section-title">{{ section.settings.who_title }}</h2>
          {% endif %}

          {% if section.settings.who_text != blank %}
            {{ section.settings.who_text }}
          {% endif %}
        </div>

        <div>
          {% if section.settings.who_image != blank %}
            {{ section.settings.who_image | image_url: width: 1600 | image_tag }}
          {% endif %}
        </div>
      </div>

      <div class="card">
        {% if section.settings.mission_title != blank %}
          <h2 class="section-title">{{ section.settings.mission_title }}</h2>
        {% endif %}

        {% if section.settings.mission_text_1 != blank %}
          {{ section.settings.mission_text_1 }}
        {% endif %}

        {% if section.settings.mission_text_2 != blank %}
          <br>
          {{ section.settings.mission_text_2 }}
        {% endif %}
      </div>

      <div class="impact-grid">
        <div class="red-card">
          {% if section.settings.impact_title != blank %}
            <h2>{{ section.settings.impact_title }}</h2>
          {% endif %}

          {% if section.settings.impact_text != blank %}
            {{ section.settings.impact_text }}
          {% endif %}
        </div>

        <div class="white-card">
          {% if section.settings.cause_title != blank %}
            <h2>{{ section.settings.cause_title }}</h2>
          {% endif %}

          {% if section.settings.cause_text != blank %}
            {{ section.settings.cause_text }}
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  <section class="section-block center">
    <div class="container">
      {% if section.settings.donate_title != blank %}
        <h2 class="section-title">{{ section.settings.donate_title }}</h2>
      {% endif %}

      {% if section.settings.donate_text != blank %}
        {{ section.settings.donate_text }}
      {% endif %}
    </div>
  </section>

  <section class="section-block">
    <div class="container">
      {% if section.settings.helped_title != blank %}
        <h2 class="section-title center">{{ section.settings.helped_title }}</h2>
      {% endif %}

      {% assign help_card_count = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'help_card' %}
          {% assign help_card_count = help_card_count | plus: 1 %}
        {% endif %}
      {% endfor %}

      <div class="help-carousel" data-help-carousel>
        <button
          type="button"
          class="help-carousel__arrow help-carousel__arrow--prev"
          aria-label="Previous slide"
          data-carousel-prev
        >
          ‹
        </button>

        <div class="help-carousel__viewport">
          <div class="help-carousel__track" data-carousel-track>
            {% for block in section.blocks %}
              {% if block.type == 'help_card' %}
                <div class="help-carousel__slide" {{ block.shopify_attributes }}>
                  <div class="help-card">
                    {% if block.settings.image != blank %}
                      {{ block.settings.image | image_url: width: 1200 | image_tag }}
                    {% endif %}

                    <div class="help-card-content">
                      {% if block.settings.title != blank %}
                        <h3>{{ block.settings.title }}</h3>
                      {% endif %}

                      {% if block.settings.amount != blank %}
                        <div class="amount">${{ block.settings.amount }}</div>
                      {% endif %}

                      {% if block.settings.goal_text != blank %}
                        <p>raised of ${{ block.settings.goal_text }} goal</p>
                      {% endif %}

                      <div class="progress">
                        <div class="progress-bar" style="width: {{ block.settings.progress }}%;"></div>
                      </div>
                      {% if block.settings.donations_count != blank %}
                        <p style="font-size:14px">{{ block.settings.donations_count }} donations</p>
                      {% endif %}
                    </div>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        <button
          type="button"
          class="help-carousel__arrow help-carousel__arrow--next"
          aria-label="Next slide"
          data-carousel-next
        >
          ›
        </button>

        <div class="help-carousel__dots" data-carousel-dots></div>
      </div>

      <div class="center responders">
        {% if section.settings.helped_button_label != blank and section.settings.helped_button_link != blank %}
          <a href="{{ section.settings.helped_button_link }}" class="btn">
            {{ section.settings.helped_button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </section>

  <section class="section-block">
    <div class="container">
      {% if section.settings.support_title != blank %}
        <h2 class="section-title center">{{ section.settings.support_title }}</h2>
      {% endif %}

      <div class="support-grid">
        {% if section.settings.support_image != blank %}
          {{ section.settings.support_image | image_url: width: 1600 | image_tag }}
        {% else %}
          <div></div>
        {% endif %}

        <div>
          {% if section.settings.support_heading != blank %}
            <h3>{{ section.settings.support_heading }}</h3>
          {% endif %}

          {% if section.settings.support_text != blank %}
            {{ section.settings.support_text }}
          {% endif %}
        </div>
      </div>

      <div class="overlay-grid">
        <div class="overlay-card">
          {% if section.settings.overlay_1_image != blank %}
            {{ section.settings.overlay_1_image | image_url: width: 1600 | image_tag }}
          {% endif %}

          <div class="overlay">
            <div class="details">
              {% if section.settings.overlay_1_title != blank %}
                <h3>{{ section.settings.overlay_1_title }}</h3>
              {% endif %}

              {% if section.settings.overlay_1_text != blank %}
                {{ section.settings.overlay_1_text }}
              {% endif %}
            </div>

            {% if section.settings.overlay_1_button_label != blank and section.settings.overlay_1_button_link != blank %}
              <a href="{{ section.settings.overlay_1_button_link }}" class="btn">
                {{ section.settings.overlay_1_button_label }}
              </a>
            {% endif %}
          </div>
        </div>

        <div class="overlay-card">
          {% if section.settings.overlay_2_image != blank %}
            {{ section.settings.overlay_2_image | image_url: width: 1600 | image_tag }}
          {% endif %}

          <div class="overlay">
            <div class="details">
              {% if section.settings.overlay_2_title != blank %}
                <h3>{{ section.settings.overlay_2_title }}</h3>
              {% endif %}

              {% if section.settings.overlay_2_text != blank %}
                {{ section.settings.overlay_2_text }}
              {% endif %}
            </div>

            {% if section.settings.overlay_2_button_label != blank and section.settings.overlay_2_button_link != blank %}
              <a href="{{ section.settings.overlay_2_button_link }}" class="btn">
                {{ section.settings.overlay_2_button_label }}
              </a>
            {% endif %}
          </div>
        </div>
      </div>

      {% if section.settings.payment_image != blank %}
        <div class="payment">
          {{ section.settings.payment_image | image_url: width: 1200 | image_tag: alt: 'Payment methods' }}
        </div>
      {% endif %}

      <div class="gallery">
        {% for block in section.blocks %}
          {% if block.type == 'gallery_image' %}
            <div {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 1200 | image_tag }}
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
</div>

<script>
  (function() {
    const section = document.querySelector('.helping-heroes-{{ section.id }}');
    if (!section) return;

    const carousel = section.querySelector('[data-help-carousel]');
    if (!carousel) return;

    const track = carousel.querySelector('[data-carousel-track]');
    const slides = Array.from(track.children);
    const prevBtn = carousel.querySelector('[data-carousel-prev]');
    const nextBtn = carousel.querySelector('[data-carousel-next]');
    const dotsWrap = carousel.querySelector('[data-carousel-dots]');

    if (!slides.length) return;

    let currentIndex = 0;
    let slidesPerView = getSlidesPerView();
    let maxIndex = getMaxIndex();

    function getSlidesPerView() {
      if (window.innerWidth <= 640) return 1;
      if (window.innerWidth <= 900) return 2;
      return 3;
    }

    function getGap() {
      return window.innerWidth <= 900 ? 16 : 24;
    }

    function getSlideWidth() {
      const slide = slides[0];
      return slide ? slide.getBoundingClientRect().width : 0;
    }

    function getMaxIndex() {
      return Math.max(0, slides.length - slidesPerView);
    }

    function buildDots() {
      dotsWrap.innerHTML = '';
      const pageCount = Math.max(1, maxIndex + 1);

      for (let i = 0; i < pageCount; i++) {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'help-carousel__dot';
        dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
        dot.addEventListener('click', () => {
          currentIndex = i;
          updateCarousel();
        });
        dotsWrap.appendChild(dot);
      }
    }

    function updateDots() {
      const dots = dotsWrap.querySelectorAll('.help-carousel__dot');
      dots.forEach((dot, index) => {
        dot.classList.toggle('is-active', index === currentIndex);
      });
    }

    function updateButtons() {
      prevBtn.disabled = currentIndex <= 0;
      nextBtn.disabled = currentIndex >= maxIndex;
    }

    function updateCarousel() {
      slidesPerView = getSlidesPerView();
      maxIndex = getMaxIndex();

      if (currentIndex > maxIndex) {
        currentIndex = maxIndex;
      }

      const offset = currentIndex * (getSlideWidth() + getGap());
      track.style.transform = `translateX(-${offset}px)`;

      buildDots();
      updateDots();
      updateButtons();
    }

    prevBtn.addEventListener('click', () => {
      if (currentIndex > 0) {
        currentIndex--;
        updateCarousel();
      }
    });

    nextBtn.addEventListener('click', () => {
      if (currentIndex < maxIndex) {
        currentIndex++;
        updateCarousel();
      }
    });

    let startX = 0;
    let isDragging = false;

    carousel.querySelector('.help-carousel__viewport').addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      isDragging = true;
    }, { passive: true });

    carousel.querySelector('.help-carousel__viewport').addEventListener('touchend', (e) => {
      if (!isDragging) return;
      const endX = e.changedTouches[0].clientX;
      const diff = startX - endX;

      if (Math.abs(diff) > 50) {
        if (diff > 0 && currentIndex < maxIndex) {
          currentIndex++;
        } else if (diff < 0 && currentIndex > 0) {
          currentIndex--;
        }
        updateCarousel();
      }

      isDragging = false;
    }, { passive: true });

    window.addEventListener('resize', updateCarousel);
    updateCarousel();
  })();

  //heroes bg carousel
  (function() {
    const hero = document.querySelector('.helping-heroes-{{ section.id }} [data-hero-carousel]');
    if (!hero) return;

    const slides = hero.querySelectorAll('.hero-bg-slide');
    if (slides.length <= 1) return;

    const autoplaySpeed = parseInt(hero.dataset.autoplaySpeed, 10) || 5000;
    let current = 0;
    let interval;

    function showSlide(index) {
      slides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === index);
      });
    }

    function nextSlide() {
      current = (current + 1) % slides.length;
      showSlide(current);
    }

    function startAutoplay() {
      interval = setInterval(nextSlide, autoplaySpeed);
    }

    function stopAutoplay() {
      clearInterval(interval);
    }

    hero.addEventListener('mouseenter', stopAutoplay);
    hero.addEventListener('mouseleave', startAutoplay);

    startAutoplay();
  })();
